# ─────────────────────────────────────────────
# Скопируйте этот файл в .env и заполните своими значениями:
#   cp .env.example .env
# ─────────────────────────────────────────────

# Токен Telegram-бота — получить у @BotFather
BOT_TOKEN=ВАШ_ТОКЕН_БОТА

# Ваш Telegram ID — узнать у @userinfobot
TELEGRAM_CHAT_ID=ВАШ_TELEGRAM_ID

# API-ключи Google Gemini — https://aistudio.google.com/apikey
# Можно использовать один и тот же ключ для обоих полей
GEMINI_API_KEY_1=ВАШ_GEMINI_КЛЮЧ_1
GEMINI_API_KEY_2=ВАШ_GEMINI_КЛЮЧ_2

# Прокси — формат host:port:login:password через запятую (можно в несколько строк в кавычках)
PROXY_HOSTS="1.2.3.4:1080:login:password,
             5.6.7.8:1080:login:password"
